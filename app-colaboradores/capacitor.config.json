{
  "appId": "com.apex.colaboradores",
  "appName": "Apex Colaboradores",
  "webDir": "dist",
  "server": {
    "androidScheme": "https"
  },
  "android": {
    "backgroundColor": "#0f172a",
    "allowMixedContent": false,
    "loggingBehavior": "none"
  },
  "plugins": {
    "SplashScreen": {
      "launchAutoHide": true,
      "launchShowDuration": 800,
      "backgroundColor": "#0f172a",
      "showSpinner": false
    }
  }
}
