# Frontend (Vite)
VITE_SUPABASE_URL=https://SEU_PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua_anon_key

# API PHP (cobrança de campo). Padrão: desligado. Use true quando o backend-php estiver no ar.
# O PDF do caixa (Tesouraria) NÃO usa PHP — só o navegador.
# VITE_BACKEND_PHP_ENABLED=true

# URL explícita em produção (opcional; vazio = mesmo host + proxy nginx/Vite)
# VITE_BACKEND_PHP_URL=https://api.suaempresa.com.br

# Proxy do Vite em dev (opcional; padrão http://127.0.0.1:8080; só com PHP enabled)
# VITE_BACKEND_PHP_PROXY_TARGET=http://127.0.0.1:8080

# Dev: use http://127.0.0.1:3000 ou http://localhost:3000 (mesmo host sempre).
# VITE_DEV_PORT=3000
# Só se o WebSocket do Vite falhar no console (opcional):
# VITE_DEV_HMR_HOST=127.0.0.1
# Para desligar hot-reload e sumir avisos ws no console (recarregue F5 após salvar):
# VITE_DISABLE_HMR=true
