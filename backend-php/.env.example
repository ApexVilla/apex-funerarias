APP_ENV=development
# Mantenha false em produção. Em dev local pode ser true para ver detalhes de erro.
APP_DEBUG=false
APP_PORT=8080
# NUNCA true em produção — só funciona quando APP_DEBUG=true (o index.php aborta caso contrário).
APP_SKIP_AUTH=false

# Mesmos valores do .env do frontend (VITE_SUPABASE_*)
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_ANON_KEY=sua_anon_key

# CORS: defina o domínio exato do app em produção (ex. https://app.suaempresa.com.br).
# Vazio = nenhum header CORS (requisições same-origin via proxy continuam funcionando).
# NUNCA use "*" em produção.
ALLOWED_ORIGIN=

# Em produção/escala, aponte DB_URL/DB_HOST para o Transaction Pooler do Supabase
# (porta 6543). Nessa porta o PDO usa prepares emulados automaticamente (pgbouncer
# em modo transaction nao suporta prepared statements server-side persistentes).
DB_URL=
DB_HOST=127.0.0.1
DB_PORT=5432
DB_FALLBACK_HOST=
DB_FALLBACK_PORT=6543
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSLMODE=require

# Rate limiting (defesa em profundidade). Janela de 60s.
RATE_LIMIT_LOGIN_MAX=20
RATE_LIMIT_WRITE_MAX=120
